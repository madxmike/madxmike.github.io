---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 - Page Not Found" description="Page not found">
  <div class="text-center">
    <h1 class="text-xl font-semibold mb-8 uppercase tracking-wide">404 - Page Not Found</h1>
    <img src="/tearboi.png" alt="Sad tear boy" class="mx-auto mb-8 max-w-full h-auto" />
    <p class="text-gray-700 dark:text-gray-300 mb-4">The page you're looking for doesn't exist.</p>
    <a href="/" class="text-orange-600 dark:text-orange-400 hover:underline">Go back home</a>
  </div>
</BaseLayout>
