---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageTitle from "../components/PageTitle.astro";
---

<BaseLayout title="404 - Page Not Found" description="Page not found">
    <div class="text-center py-12">
        <PageTitle class="mb-8">404</PageTitle>
        <img
            src="/tearboi.png"
            alt="Sad tear boy"
            class="mx-auto mb-8 max-w-xs w-full"
        />
        <p class="text-lg text-gray-700 dark:text-gray-300 mb-6">
            The page you're looking for doesn't exist.
        </p>
        <a href="/" class="inline-block text-orange-600 dark:text-orange-400 font-medium hover:underline"
            >Go back home</a
        >
    </div>
</BaseLayout>
