---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const allPosts = await getCollection('blog');
const publishedPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = publishedPosts.slice(0, 5);
---
<BaseLayout title="Michael Epps - Personal Blog" description="Personal blog by Michael Epps">
  <section>
    <h1 class="text-xl font-semibold mb-8 uppercase tracking-wide">Michael Epps</h1>
    <div class="prose">
      <p>
        Welcome to my personal blog. I write about web development, software engineering, 
        and technology. This space is where I share my thoughts, experiences, and learnings 
        from building software.
      </p>
    </div>
  </section>
</BaseLayout>
