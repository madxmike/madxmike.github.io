---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Prose from '../components/Prose.astro';
import Title from '../components/Title.astro';

const allPosts = await getCollection('blog');
const publishedPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = publishedPosts.slice(0, 5);
---
<BaseLayout title="Michael Epps - Personal Blog" description="Personal blog by Michael Epps">
  <section>
    <Title class="mb-4 desktop:mb-8">Michael Epps</Title>
    <Prose>
      <p>
        Hey, I'm Michael. I'm a software engineer at Amazon Prime Video where I work on 
        payment systems, coach other engineers, and build AI tooling for our team. 
        Most of my writing here is about the technical and leadership side of building 
        software at scale.
      </p>
      
      <p>
        Outside of work, I make games (or at least try to), read way too much sci-fi 
        and fantasy, and think about how people learn complex things. I'm particularly 
        interested in how we get better at our craft, whether that's through better tools, 
        better processes, or just better ways of thinking.
      </p>
      
      <p>
        This blog is where I write about what I'm learning, building, or thinking about. 
        Check out my writings on this blog if any of that sounds interesting.
      </p>
    </Prose>
  </section>
</BaseLayout>
