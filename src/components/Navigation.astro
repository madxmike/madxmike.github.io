---
import NavLink from './NavLink.astro';

const currentPath = Astro.url.pathname;
const isAbout = currentPath === '/';
const isWriting = currentPath.startsWith('/articles');
---
<nav class="mb-6 desktop:mb-0">
  <div class="flex gap-6 text-base desktop:flex-col desktop:gap-2">
    <NavLink href="/" isActive={isAbout}>About</NavLink>
    <NavLink href="/articles" isActive={isWriting}>Writing</NavLink>
  </div>
</nav>
