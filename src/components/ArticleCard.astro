---
interface Props {
  title: string;
  slug: string;
  pubDate: Date;
  description: string;
  tags?: string[];
}

const { title, slug, pubDate, description, tags } = Astro.props;
const formattedDate = new Date(pubDate).toLocaleDateString('en-US', { 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric' 
});
---
<article class="mb-10 pb-10 border-b border-gray-200 last:border-b-0">
  <a href={`/articles/${slug}`} class="block group">
    <h2 class="text-xl font-semibold mb-2 group-hover:underline">{title}</h2>
    <time datetime={pubDate.toISOString()} class="text-sm text-gray-600">{formattedDate}</time>
  </a>
  <p class="text-gray-700 mt-2">{description}</p>
</article>
