---
import ArticleCardTitle from './ArticleCardTitle.astro';

interface Props {
  title: string;
  slug: string;
  pubDate: Date;
  description: string;
  tags?: string[];
}

const { title, slug, pubDate, description, tags } = Astro.props;
const formattedDate = new Date(pubDate).toLocaleDateString('en-US', { 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric' 
});
---
<article class="mb-12 pb-12 border-b border-gray-200 dark:border-gray-700 last:border-b-0">
  <a href={`/articles/${slug}`} class="block group no-underline">
    <ArticleCardTitle class="mb-2 group-hover:text-orange-600 dark:group-hover:text-orange-400 transition-colors">{title}</ArticleCardTitle>
    <time datetime={pubDate.toISOString()} class="text-sm text-gray-500 dark:text-gray-500">{formattedDate}</time>
    <p class="text-gray-700 dark:text-gray-300 mt-3">{description}</p>
  </a>
</article>
