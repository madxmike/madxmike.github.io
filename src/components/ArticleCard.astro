---
interface Props {
  title: string;
  slug: string;
  pubDate: Date;
  description: string;
  tags?: string[];
}

const { title, slug, pubDate, description, tags } = Astro.props;
const formattedDate = new Date(pubDate).toLocaleDateString('en-US', { 
  year: 'numeric', 
  month: 'short', 
  day: 'numeric' 
});
---
<article class="border border-gray-200 rounded-lg p-6 hover:shadow-lg transition-shadow">
  <a href={`/articles/${slug}`} class="block">
    <h2 class="text-2xl font-bold mb-2 hover:text-blue-600 transition-colors">{title}</h2>
  </a>
  <div class="text-sm text-gray-600 mb-3">
    <time datetime={pubDate.toISOString()}>{formattedDate}</time>
    {tags && tags.length > 0 && (
      <span class="ml-3">
        {tags.map(tag => (
          <span class="inline-block bg-gray-100 rounded px-2 py-1 text-xs mr-1">{tag}</span>
        ))}
      </span>
    )}
  </div>
  <p class="text-gray-700">{description}</p>
</article>
