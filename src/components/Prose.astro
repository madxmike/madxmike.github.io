---
---
<div class="prose text-gray-800 dark:text-gray-300">
  <slot />
</div>

<style>
  @reference "../styles/global.css";
  
  .prose :global(p) {
    @apply leading-relaxed my-4;
  }
  
  .prose :global(h1), .prose :global(h2), .prose :global(h3) {
    @apply text-[17px] desktop:text-[15px] font-bold mt-8 mb-4;
  }
  
  .prose :global(code) {
    @apply text-pink-500 dark:text-pink-300 text-sm;
  }
  
  .prose :global(pre) {
    @apply bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-md p-4 overflow-x-auto my-6;
  }
  
  .prose :global(blockquote) {
    @apply border-l-4 border-gray-200 dark:border-gray-600 pl-4 my-6 italic text-gray-600 dark:text-gray-400;
  }
  
  .prose :global(ul) {
    list-style-type: disc;
    padding-left: 2.5rem;
    margin: 1rem 0;
  }
  
  .prose :global(ol) {
    list-style-type: decimal;
    padding-left: 2.5rem;
    margin: 1rem 0;
  }
</style>
