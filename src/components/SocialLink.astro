---
import { FontAwesomeIcon } from 'astro-fontawesome';

interface Props {
  href: string;
  icon: any;
  label: string;
}

const { href, icon, label } = Astro.props;
---
<a href={href} target="_blank" rel="noopener noreferrer" class="text-gray-500 dark:text-gray-500 hover:text-orange-600 dark:hover:text-orange-400 transition-colors" aria-label={label}>
  <FontAwesomeIcon icon={icon} class="w-5 h-5" />
</a>
